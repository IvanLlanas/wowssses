      function ___elapsed_date_to_string ()
      {
         local seconds y m d result empty
         seconds=$1
         empty=1
         result=

         # Years ----
         y=$(($seconds / 31536000))
         seconds=$(($seconds - $((y * 31536000))))
         if [ $y -gt 0 ]; then
            result="$y years"
            empty=0
         fi
         # Months ----
         m=$(($seconds / 2592000))
         seconds=$(($seconds - $((m * 2592000))))
         if [ $m -gt 0 ]; then
            if [ $empty -eq 0 ]; then
               result="$result, "
            fi
            result="$result$m months"
            empty=0
         fi
         # Days ----
         d=$(($seconds / 86400))
         if [ $d -gt 0 ]; then
            if [ $empty -eq 0 ]; then
               result="$result, "
            fi
            result="$result$d days"
            empty=0
         fi
         echo "$result"
      # -u avoid converting this time to local timezone.
      # echo $(date -u -d@$1 +%H:%M:%S)
      }

function ___os_version ()
{
   if type lsb_release >/dev/null 2>&1; then
