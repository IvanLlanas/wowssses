      seconds1=$(stat / --format=%W)
      seconds2=$(___get_current_time)
      ___print_info "  Installed on <2>$(___datetime_to_string $(stat / --format=%W))<0> [<3>$(___elapsed_date_to_string $(($seconds2 - $seconds1)))<0>]"

      ___print_info $_ansi_white"Session"
      os_ip=$(hostname -I 2>&1)
      ___print_info "  <1>$USER<0>[<2>$UID<0>]@<1>$HOSTNAME<0> - <3>$os_ip<0>"
