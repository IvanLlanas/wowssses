alias all=_list_aliases
   all_description="Show a list of aliases".
   all_category="$_CATEGORY_SHELL"
function _list_aliases ()
{
   local aliases str show_descr the_category i cmd cr ncmd

   ncmd=$COLUMNS
   let ncmd=ncmd-3
   let ncmd=ncmd/16

   aliases=$(compgen -a)
   show_descr=0
   i=1
   cr=0

   the_category=""
   if [[ $1 != "" ]]; then

      cmd=$1
      for str in ${_AL_CATEGORIES[@]}; do
         if [ "$str" = "$cmd" ]; then
            the_category="$str"
         fi
      done

      if [ "$the_category" = "" ]; then
         if [ "$cmd" != "?" ]; then
            str=${BASH_ALIASES[$cmd]}
            if [ "$str" = "" ]; then
               ___print_error "all" "Unknown alias $_quote1<1>$cmd<0>$_quote2."
            else
               ___print_alias 1 0 $cmd
               return
            fi
         fi
      fi
      show_descr=1
   fi

   if [ $show_descr -eq 0 ]; then
      printf "   "
   fi

   while IFS= read -r cmd ; do

      ___print_alias $show_descr 1 $cmd $the_category

      cr=0
      if [ $show_descr = 0 ]; then
         let i=i+1
         if [ $i -gt $ncmd ]; then
            printf "\n   "
            i=1
            cr=1
         fi
       fi

   done <<< "$aliases"

   if [ $show_descr -eq 0 ] && [ $cr -eq 0 ]; then
      echo
   fi
   echo
}

function ___print_alias ()
{
   local show_descr do_indent cmd only_categ base value suf varname description category c1 c2

   show_descr=$1
   do_indent=$2
   cmd=$3
   only_categ=$4

   value=${BASH_ALIASES[$cmd]}
   if [[ $value == *"sudo "* ]]; then
      suf="*"
      c1="$_ansi_lyellow"
      c2="$_ansi_off"
   else
      suf=""
      c1=
      c2=
   fi

   if [ $show_descr -gt 0 ]; then

      # varname root (cmd)
      base=${cmd//\./_}
      base=${base//\-/_}

      varname=$base"_category"
      if [[ -v $varname ]]; then
         category=${!varname}
      else
         varname="_"$varname
         if [[ -v $varname ]]; then
            category=${!varname}
         else
            category="?"
         fi
      fi

      if [ "$only_categ" != "" ]; then
         if [ "$only_categ" != "$category" ]; then
            return
         fi
      fi

      printf "   "
      echo -e -n $c1
      if [ $do_indent -gt 0 ]; then
         printf %-16s $cmd$suf
      else
         printf %s $cmd$suf
      fi
      echo -e -n $c2


      varname=$base"_description"
      if [[ -v $varname ]]; then
         description=${!varname}
      else
         varname="_"$varname
         if [[ -v $varname ]]; then
            description=${!varname}
         else
            description="?"
         fi
      fi

      c1=${_AL_CATEGORY_COLORS[$category]}
      echo -e " - [$c1$category$_ansi_off] $description"
   else
      echo -e -n $c1
      printf %-16s $cmd$suf
      echo -e -n $c2
   fi
}

function ___complete_all ()
{
   local cur opts

   # get all the aliases names
   opts=$(compgen -a)
   opts="? "${opts//$'\r'}

   COMPREPLY=()
   cur="${COMP_WORDS[COMP_CWORD]}"
   #prev="${COMP_WORDS[COMP_CWORD-1]}"

   COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
   return 0
}

