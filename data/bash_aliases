# function ___print_url (url, [text], [color])
# Prints an URL.
function ___print_url ()
{
   local url text color1 color2
   url="$1"
   text="$2"
   color1="$3"
   color2="$_ansi_off"

   if [ "$text" == "" ]; then
      text="$url"
   fi

   if [ "$color1" == "" ]; then
      printf "\e]8;;$url\e\\$text\e]8;;\e\\"
   else
      echo -en $color1
      printf "\e]8;;$url\e\\$text\e]8;;\e\\"
      echo -en $color2
   fi
}

